{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": [
            "node",
            "@playwright/test"
        ]
    },
    "include": [
        "tests",
        "pages",
        "fixtures",
        "utils",
        "playwright.config.ts"
    ]
}