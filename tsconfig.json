{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": [
            "node",
            "@playwright/test"
        ]
    },
    "include": [
        "tests",
        "pages",
        "fixtures",
        "utils",
        "playwright.config.ts",
        "pages/BaseShopPage.ts",
        "pages/AccountCreationPage.ts",
        "pages/CartPage.ts",
        "pages/CheckoutPage.ts",
        "pages/PaymentConfirmationPage.ts",
        "pages/PaymentPage.ts",
        "pages/ProductDetailPage.ts",
        "pages/ProductsPage.ts",
        "pages/ShopHomePage.ts",
        "pages/SignupLoginPage.ts"
    ]
}